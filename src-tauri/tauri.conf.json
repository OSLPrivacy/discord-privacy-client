{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Discord Privacy Client",
  "version": "0.0.1",
  "identifier": "org.discord-privacy.client",
  "build": {
    "frontendDist": "../webview/dist"
},
  "app": {
    "windows": [
      {
        "title": "Discord Privacy Client",
        "url": "https://discord.com/app",
        "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/130.0.0.0 Safari/537.36 Edg/130.0.0.0",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "fullscreen": false,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": []
  }
}
