{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Discord Privacy Client",
  "version": "0.0.1",
  "identifier": "org.discord-privacy.client",
  "build": {
    "frontendDist": "../webview/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Discord Privacy Client",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600,
        "fullscreen": false,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": []
  }
}
