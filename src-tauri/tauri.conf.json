{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OSL Privacy",
  "version": "0.0.1",
  "identifier": "org.discord-privacy.client",
  "build": {
    "frontendDist": "../webview/dist"
},
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
  "icons/32x32.png",
  "icons/128x128.png",
  "icons/128x128@2x.png",
  "icons/icon.icns",
  "icons/icon.ico"
]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["osl"]
      }
    },
    "updater": {
      "endpoints": [
        "https://keyserver.oslprivacy.com/v1/update-manifest/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ0QUQ4OUUzNkJDMTE5RjgKUldUNEdjRnI0NG10UkhZZG05UHVGbms2aFB6S0F6RGZuUFd6c1c1ZGxUUktkL2hRWVdjVWdvMjIK"
    }
  }
}
