{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Permissions granted to the discord.com main webview for OSL contextual hooks (encrypt/decrypt, channel-header toggle + tri-state whitelist icon + burn, profile-popup whitelist, gateway membership cache push). Tauri 2 blocks IPC from remote URLs by default; the `remote.urls` glob extends this capability to discord.com. Phase 7d-C: password management, recovery phrase, stealth/burn password operations are NOT reachable from this origin — they live on the trusted local settings window (osl-gate://localhost/settings) under `settings-window.json`. Whitelist/scope/burn commands stay here because the channel-header burn button + tri-state whitelist icon + profile-popup whitelist button are contextual to Discord UI. 9-C1 removed the invitation handshake (allow-osl-send-whitelist-invitation, -response, -accept-invitation, -decline-invitation, -list-pending-invitations); 9-C1 Stage 3 added bulk-set/unset-whitelist + tri-state summary + gateway membership tap.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://discord.com/*",
      "https://*.discord.com/*"
    ]
  },
  "permissions": [
    "allow-osl-encrypt-message",
    "allow-osl-decrypt-message",
    "allow-osl-load-channel-history",
    "allow-osl-burn-message",
    "allow-osl-persist-edit",
    "allow-osl-persist-outbound",
    "allow-osl-encrypt-message-v2",
    "allow-osl-seal-attachment",
    "allow-osl-open-attachment",
    "allow-osl-seal-attachment-with-cover-v2",
    "allow-osl-seal-attachment-with-cover-v3",
    "allow-osl-open-attachment-v2",
    "allow-osl-encrypt-attachment-envelope",
    "allow-osl-fetch-attachment-bytes",
    "allow-osl-send-burn-marker",
    "allow-osl-apply-burn",
    "allow-osl-unwhitelist-scope",
    "allow-osl-set-whitelist",
    "allow-osl-get-scope-encryption-state",
    "allow-osl-get-scope-whitelist-summary",
    "allow-osl-bulk-set-whitelist",
    "allow-osl-bulk-unwhitelist-scope",
    "allow-osl-toggle-scope-encryption",
    "allow-osl-set-scope-encrypt",
    "allow-osl-get-self-user-id",
    "allow-osl-get-identity-info",
    "allow-osl-list-all-whitelists",
    "allow-osl-password-status",
    "allow-osl-burn-scope-data",
    "allow-osl-burn-engage",
    "allow-osl-control-inbox-post",
    "allow-osl-control-inbox-drain",
    "allow-osl-attachment-cache-put",
    "allow-osl-attachment-cache-get",
    "allow-osl-mark-scope-burned",
    "allow-osl-unburn-scope",
    "allow-osl-list-burned-scopes",
    "allow-osl-membership-update",
    "allow-osl-membership-get",
    "allow-osl-set-friend-ids",
    "allow-osl-set-guild-list",
    "allow-osl-set-server-default",
    "allow-osl-get-server-defaults",
    "allow-osl-prose-token-send",
    "allow-osl-prose-token-recv",
    "allow-osl-prose-token-burn",
    "allow-osl-get-scope-ttl",
    "allow-osl-set-scope-ttl",
    "allow-osl-scope-burn-blobs",
    "allow-osl-is-decommissioned",
    "allow-osl-open-settings-window",
    "allow-osl-close-settings-window-if-open",
    "allow-osl-register-self-snowflake",
    "allow-osl-switch-account",
    "allow-osl-ensure-recovery-phrase",
    "allow-osl-tour-get-state",
    "allow-osl-tour-advance",
    "allow-osl-tour-complete",
    "allow-osl-tour-skip",
    "allow-osl-set-main-password",
    "allow-osl-take-last-persist-error",
    "allow-osl-take-registration-alert",
    "allow-osl-list-key-change-alerts",
    "allow-osl-accept-key-change",
    "allow-osl-reset-v4-session",
    "allow-osl-reset-v5-sender-key",
    "allow-osl-build-skdm-request",
    "allow-osl-build-session-reset",
    "allow-osl-recover-peer-identity",
    "allow-osl-note-scope-membership",
    "allow-osl-get-server-whitelist-state",
    "allow-osl-set-server-header-whitelist",
    "allow-osl-set-server-lock",
    "allow-osl-set-channel-whitelist",
    "allow-osl-decline-key-change",
    "allow-osl-test-deep-link",
    "allow-osl-get-license-state",
    "allow-osl-get-tier-gate-status",
    "core:event:allow-listen",
    "core:event:allow-emit"
  ]
}
