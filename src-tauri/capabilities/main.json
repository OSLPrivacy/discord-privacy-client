{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Permissions granted to the discord.com main webview for OSL contextual hooks (encrypt/decrypt, channel-header toggle/burn, profile-popup whitelist, invitation banners). Tauri 2 blocks IPC from remote URLs by default; the `remote.urls` glob extends this capability to discord.com. Phase 7d-C: password management, recovery phrase, stealth/burn password operations are NOT reachable from this origin — they live on the trusted local settings window (osl-gate://localhost/settings) under `settings-window.json`. Whitelist/scope/burn commands stay here because the channel-header burn button and profile-popup whitelist button are contextual to Discord UI.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://discord.com/*",
      "https://*.discord.com/*"
    ]
  },
  "permissions": [
    "allow-osl-encrypt-message",
    "allow-osl-decrypt-message",
    "allow-osl-load-channel-history",
    "allow-osl-burn-message",
    "allow-osl-persist-edit",
    "allow-osl-encrypt-message-v2",
    "allow-osl-seal-attachment",
    "allow-osl-open-attachment",
    "allow-osl-seal-attachment-with-cover-v2",
    "allow-osl-open-attachment-v2",
    "allow-osl-encrypt-attachment-envelope",
    "allow-osl-send-burn-marker",
    "allow-osl-send-whitelist-invitation",
    "allow-osl-send-whitelist-response",
    "allow-osl-apply-burn",
    "allow-osl-accept-invitation",
    "allow-osl-decline-invitation",
    "allow-osl-unwhitelist-scope",
    "allow-osl-set-whitelist",
    "allow-osl-get-scope-encryption-state",
    "allow-osl-toggle-scope-encryption",
    "allow-osl-set-scope-encrypt",
    "allow-osl-list-pending-invitations",
    "allow-osl-get-self-user-id",
    "allow-osl-get-identity-info",
    "allow-osl-list-all-whitelists",
    "allow-osl-password-status",
    "allow-osl-burn-scope-data",
    "allow-osl-mark-scope-burned",
    "allow-osl-unburn-scope",
    "allow-osl-list-burned-scopes",
    "allow-osl-open-settings-window",
    "allow-osl-close-settings-window-if-open",
    "allow-osl-register-self-snowflake",
    "core:event:allow-listen"
  ]
}
