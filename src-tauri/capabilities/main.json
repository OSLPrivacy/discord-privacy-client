{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Permissions granted to the discord.com main webview for OSL encryption hooks. Tauri 2 blocks IPC from remote URLs by default; the `remote.urls` glob extends this capability to discord.com, which is otherwise considered untrusted. The permission list is intentionally minimal — only the OSL bridge is exposed; existing Tauri commands like generate_identity, save_identity, etc. remain non-callable from Discord.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://discord.com/*",
      "https://*.discord.com/*"
    ]
  },
  "permissions": [
    "allow-osl-encrypt-message",
    "allow-osl-decrypt-message",
    "allow-osl-load-channel-history",
    "allow-osl-burn-message",
    "allow-osl-persist-edit",
    "allow-osl-encrypt-message-v2",
    "allow-osl-send-burn-marker",
    "allow-osl-send-whitelist-invitation",
    "allow-osl-send-whitelist-response",
    "allow-osl-apply-burn",
    "allow-osl-accept-invitation",
    "allow-osl-decline-invitation",
    "allow-osl-unwhitelist-scope",
    "allow-osl-set-whitelist",
    "allow-osl-get-scope-encryption-state",
    "allow-osl-toggle-scope-encryption",
    "allow-osl-list-pending-invitations",
    "allow-osl-get-self-user-id",
    "allow-osl-get-identity-info",
    "allow-osl-list-all-whitelists",
    "allow-osl-password-status",
    "allow-osl-set-main-password",
    "allow-osl-change-main-password",
    "allow-osl-remove-main-password",
    "allow-osl-view-recovery-phrase",
    "allow-osl-set-stealth-password",
    "allow-osl-remove-stealth-password",
    "allow-osl-stealth-password-status",
    "allow-osl-set-burn-password",
    "allow-osl-remove-burn-password",
    "allow-osl-burn-password-status"
  ]
}
