{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "settings-window-capability",
  "description": "Phase 7d-C: permissions granted to the local `settings` window served from osl-gate://localhost/settings. This is a trusted local origin (custom scheme, not discord.com), so it gets the broad management surface — passwords, recovery phrase, identity, whitelist mutation, scope burn — that the Discord-origin main webview no longer has. Distinct from `password-gate-capability` (which is verify-only for the boot gate page) and from `main-capability` (which only sees Discord-message operations). Add new commands here when the settings window needs them; do NOT add password / recovery / identity commands to main-capability.",
  "windows": ["settings"],
  "local": true,
  "permissions": [
    "allow-osl-get-identity-info",
    "allow-osl-list-all-whitelists",
    "allow-osl-unwhitelist-scope",
    "allow-osl-local-unwhitelist-scope",
    "allow-osl-toggle-scope-encryption",
    "allow-osl-set-scope-encrypt",
    "allow-osl-send-burn-marker",
    "allow-osl-apply-burn",
    "allow-osl-burn-scope-data",
    "allow-osl-mark-scope-burned",
    "allow-osl-unburn-scope",
    "allow-osl-list-burned-scopes",
    "allow-osl-get-self-user-id",
    "allow-osl-password-status",
    "allow-osl-set-main-password",
    "allow-osl-change-main-password",
    "allow-osl-remove-main-password",
    "allow-osl-view-recovery-phrase",
    "allow-osl-set-stealth-password",
    "allow-osl-remove-stealth-password",
    "allow-osl-stealth-password-status",
    "allow-osl-set-burn-password",
    "allow-osl-remove-burn-password",
    "allow-osl-burn-password-status",
    "allow-osl-get-app-preferences",
    "allow-osl-set-app-preferences",
    "allow-osl-get-friend-ids",
    "allow-osl-get-guild-list",
    "allow-osl-bulk-set-dm-whitelist",
    "allow-osl-bulk-set-whitelist",
    "allow-osl-set-server-default",
    "allow-osl-get-server-defaults",
    "allow-osl-apply-server-default-to-existing-channels",
    "allow-osl-tour-get-state",
    "allow-osl-tour-advance",
    "allow-osl-tour-complete",
    "allow-osl-tour-skip",
    "allow-osl-tour-reset",
    "allow-osl-vpn-warning-reset",
    "allow-osl-take-last-persist-error",
    "allow-osl-take-registration-alert",
    "allow-osl-list-key-change-alerts",
    "allow-osl-accept-key-change",
    "allow-osl-reset-v4-session",
    "allow-osl-decline-key-change",
    "allow-osl-peer-safety-number",
    "allow-osl-self-safety-number",
    "allow-osl-close-settings-window-if-open",
    "allow-osl-validate-license",
    "allow-osl-get-license-state",
    "allow-osl-clear-license",
    "allow-osl-get-tier-gate-status",
    "allow-osl-check-for-updates",
    "allow-osl-install-update",
    "allow-osl-get-update-channel",
    "allow-osl-set-update-channel",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-show",
    "core:window:allow-hide"
  ]
}
