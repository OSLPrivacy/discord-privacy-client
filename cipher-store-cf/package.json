{
  "name": "oslprivacy-cipher-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OSL short-TTL E2E-ciphertext store on Cloudflare Workers + D1, with no application-level identity binding.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply osl-cipher-store-prod --local",
    "db:migrate:prod": "wrangler d1 migrations apply osl-cipher-store-prod --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
