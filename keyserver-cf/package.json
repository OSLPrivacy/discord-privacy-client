{
  "name": "oslprivacy-keyserver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OSL keyserver on Cloudflare Workers + D1. F1.1 baseline: ports the existing keyserver/ (Fastify + better-sqlite3) endpoint surface 1:1. F1.2 layers Stripe + license issuance on top.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply osl-keyserver-prod --local",
    "db:migrate:prod": "wrangler d1 migrations apply osl-keyserver-prod --remote"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.5.0",
    "vitest": "2.1.0",
    "wrangler": "^3.78.0"
  }
}
